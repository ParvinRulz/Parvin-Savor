doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Breakfast Menu
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css' rel='stylesheet')
  style.
    .btn-outline-secondary {
    background-color: #fd5f97 !important;
    border-color: #fd5f97 !important;
    color: white;
    }
// NavBar (neutral color)
nav.navbar.navbar-expand-lg.navbar-light.bg-light.mb-4
  .container-fluid
    a.navbar-brand(href='#') Main Menu
    button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav')
      span.navbar-toggler-icon
    #navbarNav.collapse.navbar-collapse
      ul.navbar-nav.ms-auto
        li.nav-item
          a.nav-link.active(href='#') Home
        li.nav-item
          a.nav-link(href='#') Breakfast
        li.nav-item
          a.nav-link(href='#') Lunch
        li.nav-item
          a.nav-link(href='#') Dinner
        li.nav-item
          a.nav-link(href='#') Desert
        li.nav-item
          a.nav-link(href='#') Drinks &amp; Cocktails
// Header
.container.mb-4
  h1.text-center.mb-3 Breakfast Menu
  p.text-center
    | This is where we have our different starters of the day. Feel free to
    | order as your cravings desire.
// Beverages Section
.container.mb-5
  h2.mb-3 Beverages
  .row.g-4
    .col-md-4
      .card.h-100
        img.card-img-top(src='/Assets/breakfast/blacktea.avif' alt='Black Tea')
        .card-body
          h5.card-title Black Tea
          p.card-text Hot tea to start your day.
          p.fw-bold UGX 10,000
    .col-md-4
      .card.h-100
        img.card-img-top(src='/Assets/breakfast/milk.avif' alt='Milk Tea')
        .card-body
          h5.card-title Milk Tea
          p.card-text Fresh milk just as you like it.
          p.fw-bold UGX 15,000
    .col-md-4
      .card.h-100
        img.card-img-top(src='/Assets/breakfast/coffee.jpg' alt='Coffee')
        .card-body
          h5.card-title Coffee
          p.card-text Strong yet refreshing.
          p.fw-bold UGX 20,000
    .col-md-4
      .card.h-100
        img.card-img-top(src='/Assets/breakfast/greentea.avif' alt='Green Tea')
        .card-body
          h5.card-title Oregano Green Tea
          p.card-text Healthy flavoured tea.
          p.fw-bold UGX 25,000
    .col-md-4
      .card.h-100
        img.card-img-top(src='/Assets/breakfast/cocktail.jpg' alt='Juices')
        img.card-img-top.mt-2(src='/Assets/breakfast/juices12.jpg' alt='Three Glass Juices')
        .card-body
          h5.card-title Juices
          p.card-text Different juices available in all flavours and colors.
          p.fw-bold UGX 15,000
// Snacks Section
.container.mb-5
  h2.mb-3 Snacks
  .row.g-4
    .col-md-4
      .card.h-100
        img.card-img-top(src='/Assets/breakfast/c1.avif' alt='Croissant')
        .card-body
          h5.card-title Croissant
          p.card-text Fresh bread made to your design.
          p.fw-bold UGX 20,000
    .col-md-4
      .card.h-100
        img.card-img-top(src='/Assets/breakfast/scrabled egg.jpg' alt='Omelette')
        .card-body
          h5.card-title Omelette
          p.card-text Fried eggs taste.
          p.fw-bold UGX 15,000
    .col-md-4
      .card.h-100
        img.card-img-top(src='/Assets/breakfast/cabbas.jpg' alt='Kebabs')
        .card-body
          h5.card-title Kebabs
          p.card-text Taste this delicacy wrapped in eggs, flour, and meat.
          p.fw-bold UGX 15,000
    .col-md-4
      .card.h-100
        img.card-img-top(src='/Assets/breakfast/sausages.avif' alt='Sausages')
        .card-body
          h5.card-title Sausages
          p.card-text Soft and tender.
          p.fw-bold UGX 10,000
    .col-md-4
      .card.h-100
        img.card-img-top(src='/Assets/breakfast/potatowedge.jpg' alt='Potato Wedges')
        .card-body
          h5.card-title Potato Wedges
          p.card-text Fries at their best.
          p.fw-bold UGX 30,000
    .col-md-4
      .card.h-100
        img.card-img-top(src='/Assets/breakfast/w1.avif' alt='Waffles')
        .card-body
          h5.card-title Waffles
          p.card-text Layered with fruits and honey.
          p.fw-bold UGX 30,000
// Main Foods Section
.container.mb-5
  h2.mb-3 Foods
  .row.g-4
    .col-md-4
      .card.h-100
        img.card-img-top(src='/Assets/breakfast/chikenkatogo.jpg' alt='Chicken Katogo')
        img.card-img-top.mt-2(src='/Assets/breakfast/beefkatogo.jpg' alt='Beef Katogo')
        .card-body
          h5.card-title Katogo
          p.card-text Mattoke and Irish in the mix with some good stew.
          p.fw-bold UGX 20,000
    .col-md-4
      .card.h-100
        .card-body
          h5.card-title Egg Fried Rice
          p.card-text Fried rice in eggs together.
          p.fw-bold UGX 15,000
    .col-md-4
      .card.h-100
        img.card-img-top(src='/Assets/breakfast/pasta2.avif' alt='Spaghetti')
        .card-body
          h5.card-title Spaghetti
          p.card-text Fried macrons in different shapes.
          p.fw-bold UGX 20,000
section.container.text-center.mt-5
  a.btn.btn-outline-secondary.mt-3(href='lunch.html')
    | Order Lunch
// Footer
footer.bg-light.text-center.mt-5.p-3
  p.mb-0 &copy; 2026 Parvin Savor Resort. All rights reserved.
script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js')
