doctype html
| PASTE YOUR HTML CODE HERE
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Main Menu
  // Bootstrap
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css' rel='stylesheet')
  style.
    body {
    background-color: white;
    }
    /* Background Image Cards */
    .menu-img {
    width: 100%;
    height: 200px;
    background-size: cover;
    background-position: center;
    border-radius: 12px;
    position: relative;
    display: flex;
    align-items: end;
    padding: 10px;
    color: white;
    font-weight: bold;
    }
    /* Dark overlay */
    .menu-img::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.35);
    border-radius: 12px;
    }
    .menu-img span {
    position: relative;
    z-index: 2;
    }
    h5 {
    margin-top: 10px;
    }
    .btn-outline-secondary {
    background-color: #fd5f97 !important;
    border-color: #fd5f97 !important;
    color: white;
    }
// Navbar
nav.navbar.navbar-expand-lg.bg-body-tertiary
  .container
    a.navbar-brand(href='#') Main Menu
    button.navbar-toggler(data-bs-toggle='collapse' data-bs-target='#navbarNav')
      span.navbar-toggler-icon
    #navbarNav.collapse.navbar-collapse
      ul.navbar-nav.ms-auto
        li.nav-item
          a.nav-link.active(href='#') Home
        li.nav-item
          a.nav-link(href='#') Breakfast
        li.nav-item
          a.nav-link(href='#') Lunch
        li.nav-item
          a.nav-link(href='#') Dinner
        li.nav-item
          a.nav-link(href='#') Desert
        li.nav-item
          a.nav-link(href='#') Drinks &amp; Cocktails
// Content
.container.mt-4
  ul.list-group
    // Breakfast
    li.list-group-item
      h5 Breakfast
      p Available from 7:00AM - 11:00AM
      .row
        .col-md-4.mb-3
          .menu-img(style="background-image: url('/Assets/mainmenu/eggfry.jpg');")
            span Egg &amp; Fries
        .col-md-4.mb-3
          .menu-img(style="background-image: url('/Assets/mainmenu/grilled-sausages-.jpg');")
            span Sausages
        .col-md-4.mb-3
          .menu-img(style="background-image: url('/Assets/mainmenu/samosa.jpg');")
            span Samosas
    // Lunch
    li.list-group-item
      h5 Lunch
      p Available from 11:30AM - 3:00PM
      .row
        .col-md-6.mb-3
          .menu-img(style="background-image: url('/Assets/mainmenu/pasta1.avif');")
            span Pasta
        .col-md-6.mb-3
          .menu-img(style="background-image: url('/Assets/mainmenu/roasted-chicken-.avif');")
            span Roasted Chicken
    // Dinner
    li.list-group-item
      h5 Dinner
      p Available from 5:00PM - 10:00PM
      .row
        .col-md-6.mb-3
          .menu-img(style="background-image: url('/Assets/mainmenu/pasta2.avif');")
            span Pasta
        .col-md-6.mb-3
          .menu-img(style="background-image: url('/Assets/mainmenu/rice2.avif');")
            span Rice &amp; Chicken
    // Dessert
    li.list-group-item
      h5 Desert
      p Sweet treats for any time
      .row
        .col-md-6.mb-3
          .menu-img(style="background-image: url('/Assets/mainmenu/redvelvet.jpg');")
            span Red Velvet Cake
        .col-md-6.mb-3
          .menu-img(style="background-image: url('/Assets/mainmenu/vanilla.avif');")
            span Ice Cream
    // Drinks
    li.list-group-item
      h5 Drinks &amp; Cocktails
      p Artisanal Beverages &amp; Fine Wine
      .row
        .col-md-6.mb-3
          .menu-img(style="background-image: url('/Assets/mainmenu/Blue-Lagoon.jpg');")
            span Blue Lagoon
        .col-md-6.mb-3
          .menu-img(style="background-image: url('/Assets/mainmenu/cocktails.jpg');")
            span Juices
section.container.text-center.mt-5
  a.btn.btn-outline-secondary.mt-3(href='breakfast.html')
    | Order Breakfast
// Footer
footer.bg-light.text-center.mt-5.p-3
